# ============================================================
# The Nest — Environment Variable Reference
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ============================================================

# REQUIRED — JWT signing secret. Must be a strong random value.
# Generate one with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHAR_SECRET

# REQUIRED — The URL users access the app from (used for CORS).
# In Docker this is typically the host:port you expose, e.g. http://localhost:5000
# or your domain, e.g. https://nest.example.com
CLIENT_URL=http://localhost:5000

# Server port (default: 5000)
PORT=5000

# Node environment: production | development
NODE_ENV=production

# Timezone for date/time operations.
# Critical for weekly/monthly/quarterly goals to reset at the correct local time.
# Examples: Australia/Sydney, America/New_York, Europe/London, UTC
TZ=UTC

# Set to "true" when running inside Docker to use /app/data for the database.
# Do not set this in local development.
DOCKER_ENV=true

# Linux file permission mapping (Docker only).
# Set to match your host user: run `id -u` and `id -g` to find your values.
PUID=1001
PGID=1001

# Emergency password reset — use only if locked out of the admin account.
# Set both variables, restart the container, then REMOVE them and restart again.
# EMERGENCY_RESET_USER=admin
# EMERGENCY_RESET_PASSWORD=your_new_password_here
